---
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { siteConfig } from "../config";
import "../assets/app.css";

interface Props {
  title?: string;
}

const { title = `${siteConfig.name} ${siteConfig.surname}` } = Astro.props as Props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href={import.meta.env.BASE_URL + "favicon.svg"} />
		<link rel="icon" href={import.meta.env.BASE_URL + "favicon.ico"} />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={`Portfolio of ${siteConfig.name} ${siteConfig.surname} - ${siteConfig.bio}`} />
		<meta name="theme-color" content="#0a0a0f" />
		
		<!-- Preconnect to Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		
		<title>{title}</title>
	</head>
	<body class="min-h-screen flex flex-col bg-[#0a0a0f] text-gray-100 grain-overlay antialiased">
		<Navbar />
		<main class="flex-1">
			<slot />
		</main>
		<Footer />
	</body>
</html>

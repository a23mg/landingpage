---
import Layout from "../layouts/Layout.astro";
import { siteConfig } from "../config";
---

<Layout title={`About | ${siteConfig.name} ${siteConfig.surname}`}>
  <section class="py-16 px-4 max-w-4xl mx-auto">
    <div class="bg-gray-800/50 rounded-2xl shadow-xl p-8 animate-fade-in-up">
      <div class="flex flex-col md:flex-row gap-8 items-center md:items-start w-full">
        <div>
          <div class="w-40 h-40 rounded-full ring-2 ring-purple-500 ring-offset-gray-900 ring-offset-4 overflow-hidden avatar-glow">
            <img
              src={siteConfig.photoUrl}
              alt={`${siteConfig.name} ${siteConfig.surname}`}
              class="object-cover w-full h-full"
            />
          </div>
        </div>
        <div class="flex-1 text-center md:text-left">
          <h1 class="text-4xl font-extrabold text-gradient mb-4">About Me</h1>
          <p class="text-lg leading-relaxed text-gray-400">{siteConfig.bio}</p>
        </div>
      </div>
    </div>

    <div class="border-t border-gray-700/50 my-10"></div>

    <div class="animate-fade-in-up" style="animation-delay:0.2s">
      <h2 class="text-2xl font-extrabold text-gradient mb-6">Skills</h2>
      <div class="flex flex-wrap gap-3">
        {siteConfig.skills.map((skill) => (
          <span class="inline-block px-4 py-1.5 text-sm font-semibold rounded-full bg-purple-600/20 text-purple-300 border border-purple-500/30 shadow-sm hover:shadow-md hover:scale-105 transition-all duration-200 cursor-default">{skill}</span>
        ))}
      </div>
    </div>
  </section>
</Layout>

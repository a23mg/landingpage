---
import Layout from "../layouts/Layout.astro";
import { siteConfig } from "../config";
---

<Layout title={`About | ${siteConfig.name} ${siteConfig.surname}`}>
  <section class="py-16 px-4 max-w-4xl mx-auto">
    <div class="card bg-base-200/50 shadow-xl animate-fade-in-up">
      <div class="card-body items-center md:items-start">
        <div class="flex flex-col md:flex-row gap-8 items-center md:items-start w-full">
          <div class="avatar">
            <div class="w-40 h-40 rounded-full ring-2 ring-primary ring-offset-base-100 ring-offset-4 overflow-hidden avatar-glow">
              <img
                src={siteConfig.photoUrl}
                alt={`${siteConfig.name} ${siteConfig.surname}`}
                class="object-cover w-full h-full"
              />
            </div>
          </div>
          <div class="flex-1 text-center md:text-left">
            <h1 class="text-4xl font-extrabold text-gradient mb-4">About Me</h1>
            <p class="text-lg leading-relaxed text-base-content/70">{siteConfig.bio}</p>
          </div>
        </div>
      </div>
    </div>

    <div class="divider my-10"></div>

    <div class="animate-fade-in-up" style="animation-delay:0.2s">
      <h2 class="text-2xl font-extrabold text-gradient mb-6">Skills</h2>
      <div class="flex flex-wrap gap-3">
        {siteConfig.skills.map((skill) => (
          <span class="badge badge-primary badge-lg shadow-sm hover:shadow-md hover:scale-105 transition-all duration-200 cursor-default">{skill}</span>
        ))}
      </div>
    </div>
  </section>
</Layout>

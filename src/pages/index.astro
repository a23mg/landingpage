---
import Layout from "../layouts/Layout.astro";
import { siteConfig } from "../config";

const greetings = [
  `Hi, I'm ${siteConfig.name} ${siteConfig.surname}`,
  `Welcome, I'm ${siteConfig.nickname}`,
  `Hey there! I'm ${siteConfig.name}`,
  `Hello! Call me ${siteConfig.nickname}`,
  `Nice to meet you, I'm ${siteConfig.name} ${siteConfig.surname}`,
];

const skills = [
  "JavaScript", "TypeScript", "React", "Vue", "Node.js", "Python",
  "TailwindCSS", "PostgreSQL", "MongoDB", "AWS", "Docker", "Git"
];

const experiences = [
  {
    title: "Senior Developer",
    company: "Tech Company",
    period: "2022 - Present",
    description: "Leading development of modern web applications with cutting-edge technologies."
  },
  {
    title: "Full Stack Developer",
    company: "Digital Agency",
    period: "2020 - 2022",
    description: "Built scalable web solutions for various clients across different industries."
  },
  {
    title: "Junior Developer",
    company: "Startup Inc",
    period: "2018 - 2020",
    description: "Developed and maintained frontend applications using React and Vue.js."
  }
];
---

<Layout>
  <!-- Hero Section -->
  <section id="hero" class="min-h-screen flex items-center justify-center relative overflow-hidden">
    <!-- Background orbs -->
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>
    
    <!-- Grid pattern overlay -->
    <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-[size:60px_60px] [mask-image:radial-gradient(ellipse_at_center,black_20%,transparent_70%)]"></div>
    
    <!-- Cursor glow effect -->
    <div id="cursor-glow" class="cursor-glow hidden lg:block"></div>

    <div class="flex flex-col-reverse lg:flex-row-reverse items-center w-full max-w-6xl gap-12 lg:gap-24 px-6 relative z-10 pt-24 pb-12">
      <!-- Avatar -->
      <div class="flex-shrink-0 animate-scale-in stagger-2">
        <div class="relative">
          <!-- Decorative ring -->
          <div class="absolute -inset-4 rounded-full border border-purple-500/20 animate-[spin_20s_linear_infinite]"></div>
          <div class="absolute -inset-8 rounded-full border border-purple-500/10 animate-[spin_30s_linear_infinite_reverse]"></div>
          
          <div class="w-52 h-52 lg:w-80 lg:h-80 rounded-full ring-2 ring-purple-500/50 ring-offset-[#0a0a0f] ring-offset-4 overflow-hidden avatar-glow transition-all duration-500 hover:ring-purple-400">
            <img
              src={siteConfig.photoUrl}
              alt={`${siteConfig.name} ${siteConfig.surname}`}
              class="object-cover w-full h-full transition-transform duration-700 hover:scale-110"
            />
          </div>
          
          <!-- Status indicator -->
          <div class="absolute bottom-4 right-4 flex items-center gap-2 glass px-3 py-1.5 rounded-full">
            <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
            <span class="text-xs text-gray-300 font-medium">Available</span>
          </div>
        </div>
      </div>

      <!-- Content -->
      <div class="text-center lg:text-left space-y-8">
        <div class="space-y-4">
          <p class="text-purple-400 font-medium tracking-widest uppercase text-sm animate-fade-in-up stagger-1">
            Welcome to my portfolio
          </p>
          <h1 
            id="greeting-text" 
            class="text-4xl sm:text-5xl lg:text-7xl font-extrabold text-gradient leading-[1.1] tracking-tight animate-fade-in-up stagger-2" 
            data-greetings={JSON.stringify(greetings)}
          >
            {greetings[0]}
          </h1>
        </div>
        
        <p class="text-lg lg:text-xl max-w-lg text-gray-400 leading-relaxed animate-fade-in-up stagger-3">
          {siteConfig.bio}
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start animate-fade-in-up stagger-4">
          <a 
            href="#about" 
            class="magnetic-btn btn-shine inline-flex items-center justify-center px-8 py-4 text-lg font-semibold rounded-xl bg-gradient-to-r from-purple-600 to-purple-700 text-white shadow-lg shadow-purple-600/25 hover:shadow-purple-600/40 hover:from-purple-500 hover:to-purple-600 transition-all duration-300"
          >
            <span>About Me</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </a>
          <a 
            href="#contact" 
            class="magnetic-btn inline-flex items-center justify-center px-8 py-4 text-lg font-semibold rounded-xl glass border border-purple-500/30 text-purple-300 hover:bg-purple-500/10 hover:border-purple-400/50 hover:text-purple-200 transition-all duration-300"
          >
            <span>Get in Touch</span>
          </a>
        </div>

        <!-- Scroll indicator -->
        <div class="hidden lg:flex items-center gap-3 pt-8 animate-fade-in-up stagger-5">
          <div class="w-6 h-10 rounded-full border-2 border-gray-600 flex items-start justify-center p-1">
            <div class="w-1.5 h-2.5 rounded-full bg-purple-400 animate-bounce"></div>
          </div>
          <span class="text-sm text-gray-500">Scroll to explore</span>
        </div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="min-h-screen relative py-32 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-purple-900/5 to-transparent pointer-events-none"></div>
    
    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <div class="scroll-reveal opacity-0 translate-y-12">
        <p class="text-purple-400 font-medium tracking-widest uppercase text-sm mb-4">Get to know me</p>
        <h2 class="text-4xl lg:text-6xl font-bold text-gradient mb-16">About Me</h2>
      </div>
      
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="space-y-8 scroll-reveal opacity-0 translate-y-12" style="transition-delay: 0.1s;">
          <p class="text-xl text-gray-300 leading-relaxed">
            I'm a passionate developer with a love for creating beautiful, functional, and user-centered digital experiences. With years of experience in web development, I bring ideas to life through clean code and thoughtful design.
          </p>
          <p class="text-lg text-gray-400 leading-relaxed">
            When I'm not coding, you can find me exploring new technologies, contributing to open-source projects, or sharing my knowledge with the developer community.
          </p>
          
          <div class="pt-4">
            <a 
              href="#experience" 
              class="inline-flex items-center gap-2 text-purple-400 hover:text-purple-300 transition-colors duration-300 group"
            >
              <span class="link-hover">View my experience</span>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </a>
          </div>
        </div>
        
        <!-- Skills -->
        <div class="scroll-reveal opacity-0 translate-y-12" style="transition-delay: 0.2s;">
          <h3 class="text-sm font-semibold text-gray-300 uppercase tracking-widest mb-6">Technologies I work with</h3>
          <div class="flex flex-wrap gap-3">
            {skills.map((skill, index) => (
              <span 
                class="skill-tag glass px-4 py-2 rounded-lg text-gray-300 text-sm font-medium hover:bg-purple-500/10 hover:text-purple-300 hover:border-purple-500/30 transition-all duration-300 cursor-default"
                style={`transition-delay: ${index * 0.05}s;`}
              >
                {skill}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Experience Section -->
  <section id="experience" class="min-h-screen relative py-32 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-purple-900/5 to-transparent pointer-events-none"></div>
    
    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <div class="scroll-reveal opacity-0 translate-y-12">
        <p class="text-purple-400 font-medium tracking-widest uppercase text-sm mb-4">My journey</p>
        <h2 class="text-4xl lg:text-6xl font-bold text-gradient mb-16">Experience</h2>
      </div>
      
      <div class="relative">
        <!-- Timeline line -->
        <div class="absolute left-0 lg:left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-purple-500/50 via-purple-500/20 to-transparent transform lg:-translate-x-1/2"></div>
        
        <div class="space-y-16">
          {experiences.map((exp, index) => (
            <div class={`relative flex flex-col lg:flex-row gap-8 ${index % 2 === 0 ? 'lg:flex-row' : 'lg:flex-row-reverse'}`}>
              <!-- Timeline dot -->
              <div class="absolute left-0 lg:left-1/2 w-4 h-4 rounded-full bg-purple-500 border-4 border-[#0a0a0f] transform lg:-translate-x-1/2 z-10 timeline-dot"></div>
              
              <!-- Content -->
              <div class={`lg:w-1/2 ${index % 2 === 0 ? 'lg:pr-16 lg:text-right' : 'lg:pl-16'} pl-8 lg:pl-0 scroll-reveal opacity-0 translate-y-12`} style={`transition-delay: ${index * 0.15}s;`}>
                <div class="glass rounded-2xl p-8 card-hover">
                  <span class="text-purple-400 text-sm font-medium">{exp.period}</span>
                  <h3 class="text-2xl font-bold text-white mt-2">{exp.title}</h3>
                  <p class="text-gray-400 mt-1">{exp.company}</p>
                  <p class="text-gray-500 mt-4 leading-relaxed">{exp.description}</p>
                </div>
              </div>
              
              <!-- Spacer for alternating layout -->
              <div class="hidden lg:block lg:w-1/2"></div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Contact CTA Section -->
  <section id="cta" class="relative py-32 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-t from-purple-900/20 to-transparent pointer-events-none"></div>
    
    <div class="max-w-4xl mx-auto px-6 text-center relative z-10">
      <div class="scroll-reveal opacity-0 translate-y-12">
        <p class="text-purple-400 font-medium tracking-widest uppercase text-sm mb-4">Let's work together</p>
        <h2 class="text-4xl lg:text-6xl font-bold text-gradient mb-8">Have a project in mind?</h2>
        <p class="text-xl text-gray-400 mb-12 max-w-2xl mx-auto">
          I'm always open to discussing new projects, creative ideas, or opportunities to be part of your vision.
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a 
            href={`mailto:${siteConfig.email}`}
            class="magnetic-btn btn-shine inline-flex items-center justify-center px-10 py-5 text-lg font-semibold rounded-xl bg-gradient-to-r from-purple-600 to-purple-700 text-white shadow-lg shadow-purple-600/25 hover:shadow-purple-600/40 hover:from-purple-500 hover:to-purple-600 transition-all duration-300"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <span>Get in Touch</span>
          </a>
          <a 
            href={siteConfig.githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="magnetic-btn inline-flex items-center justify-center px-10 py-5 text-lg font-semibold rounded-xl glass border border-purple-500/30 text-purple-300 hover:bg-purple-500/10 hover:border-purple-400/50 hover:text-purple-200 transition-all duration-300"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-3" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
            </svg>
            <span>View GitHub</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  // Greeting rotation
  const el = document.getElementById("greeting-text");
  if (el) {
    const raw = el.dataset.greetings || "[]";
    const parsed: unknown = JSON.parse(raw);
    const greetings = Array.isArray(parsed) ? parsed.filter((g): g is string => typeof g === "string") : [];
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (greetings.length > 1 && !prefersReducedMotion) {
      let idx = 0;
      setInterval(() => {
        idx = (idx + 1) % greetings.length;
        el.style.opacity = "0";
        el.style.transform = "translateY(10px)";
        setTimeout(() => {
          el.textContent = greetings[idx];
          el.style.opacity = "1";
          el.style.transform = "translateY(0)";
        }, 300);
      }, 4000);
    }
  }

  // Cursor glow effect
  const cursorGlow = document.getElementById("cursor-glow");
  if (cursorGlow) {
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (!prefersReducedMotion) {
      document.addEventListener("mousemove", (e) => {
        requestAnimationFrame(() => {
          cursorGlow.style.left = e.clientX + "px";
          cursorGlow.style.top = e.clientY + "px";
        });
      });
    }
  }

  // Magnetic button effect
  const magneticBtns = document.querySelectorAll(".magnetic-btn");
  magneticBtns.forEach((btn) => {
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (prefersReducedMotion) return;
    
    btn.addEventListener("mousemove", (e) => {
      const rect = (btn as HTMLElement).getBoundingClientRect();
      const x = (e as MouseEvent).clientX - rect.left - rect.width / 2;
      const y = (e as MouseEvent).clientY - rect.top - rect.height / 2;
      (btn as HTMLElement).style.transform = `translate(${x * 0.15}px, ${y * 0.15}px)`;
    });
    
    btn.addEventListener("mouseleave", () => {
      (btn as HTMLElement).style.transform = "translate(0, 0)";
    });
  });

  // Scroll reveal animation
  const scrollRevealElements = document.querySelectorAll(".scroll-reveal");
  
  const revealOnScroll = () => {
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    
    scrollRevealElements.forEach((el) => {
      const rect = el.getBoundingClientRect();
      const isVisible = rect.top < window.innerHeight * 0.85;
      
      if (isVisible) {
        if (prefersReducedMotion) {
          (el as HTMLElement).style.opacity = "1";
          (el as HTMLElement).style.transform = "translateY(0)";
        } else {
          el.classList.add("revealed");
        }
      }
    });
  };

  // Timeline dots animation
  const timelineDots = document.querySelectorAll(".timeline-dot");
  
  const animateDots = () => {
    timelineDots.forEach((dot) => {
      const rect = dot.getBoundingClientRect();
      const isVisible = rect.top < window.innerHeight * 0.7;
      
      if (isVisible) {
        dot.classList.add("dot-active");
      }
    });
  };

  // Parallax effect for orbs
  const orbs = document.querySelectorAll(".orb");
  
  const parallaxOrbs = () => {
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (prefersReducedMotion) return;
    
    const scrollY = window.scrollY;
    orbs.forEach((orb, index) => {
      const speed = 0.1 + index * 0.05;
      (orb as HTMLElement).style.transform = `translateY(${scrollY * speed}px)`;
    });
  };

  // Run on load and scroll
  window.addEventListener("load", () => {
    revealOnScroll();
    animateDots();
  });
  
  window.addEventListener("scroll", () => {
    revealOnScroll();
    animateDots();
    parallaxOrbs();
  }, { passive: true });
</script>

<style>
  #greeting-text {
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .scroll-reveal {
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), 
                transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .scroll-reveal.revealed {
    opacity: 1 !important;
    transform: translateY(0) !important;
  }

  .timeline-dot {
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 0.5s ease;
  }

  .timeline-dot.dot-active {
    transform: translateX(-50%) scale(1.2);
    box-shadow: 0 0 20px 5px oklch(0.6 0.25 270 / 0.5);
  }

  .skill-tag {
    opacity: 0;
    transform: translateY(10px);
    animation: fadeInUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .scroll-reveal.revealed .skill-tag {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-reveal {
      opacity: 1 !important;
      transform: none !important;
      transition: none;
    }

    .skill-tag {
      opacity: 1;
      transform: none;
      animation: none;
    }

    .timeline-dot {
      transition: none;
    }
  }
</style>

---
import Layout from "../layouts/Layout.astro";
import { siteConfig } from "../config";
---

<Layout title={`Experience | ${siteConfig.name} ${siteConfig.surname}`}>
  <section class="py-16 px-4 max-w-4xl mx-auto">
    <h1 class="text-4xl font-extrabold text-gradient mb-10 text-center animate-fade-in-up">Experience</h1>

    <div class="relative">
      <!-- Vertical line -->
      <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-0.5 bg-purple-500/30 -translate-x-1/2"></div>

      {siteConfig.experience.map((exp, i) => (
        <div class={`relative flex flex-col md:flex-row items-start mb-10 animate-fade-in-up ${i % 2 === 0 ? 'md:flex-row-reverse' : ''}`} style={`animation-delay: ${i * 0.15}s;`}>
          <!-- Timeline dot -->
          <div class="absolute left-4 md:left-1/2 -translate-x-1/2 mt-1">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-5 w-5 text-purple-500 drop-shadow-[0_0_4px_oklch(0.6_0.25_270_/_0.5)]">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
            </svg>
          </div>

          <!-- Card -->
          <div class={`ml-12 md:ml-0 md:w-[calc(50%-2rem)] ${i % 2 === 0 ? 'md:mr-auto md:text-right md:pr-0 md:ml-auto md:pl-8' : 'md:mr-auto md:pr-8'} bg-gray-800/50 rounded-xl p-5 shadow-md hover:shadow-lg transition-shadow duration-300`}>
            <time class="font-mono italic text-gray-500">{exp.period}</time>
            <div class="text-lg font-black text-gray-100">{exp.title}</div>
            <div class="text-sm font-semibold text-purple-400">{exp.company}</div>
            <p class="mt-1 text-gray-400">{exp.description}</p>
          </div>
        </div>
      ))}
    </div>
  </section>
</Layout>

---
import Layout from "../layouts/Layout.astro";
import { siteConfig } from "../config";
---

<Layout title={`Experience | ${siteConfig.name} ${siteConfig.surname}`}>
  <section class="py-16 px-4 max-w-4xl mx-auto">
    <h1 class="text-4xl font-bold mb-10 text-center">Experience</h1>

    <ul class="timeline timeline-snap-icon max-md:timeline-compact timeline-vertical">
      {siteConfig.experience.map((exp, i) => (
        <li>
          {i > 0 && <hr class="bg-primary" />}
          <div class="timeline-middle">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-5 w-5 text-primary">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
            </svg>
          </div>
          <div class={`timeline-${i % 2 === 0 ? 'start' : 'end'} mb-10 ${i % 2 === 0 ? 'md:text-end' : ''}`}>
            <time class="font-mono italic">{exp.period}</time>
            <div class="text-lg font-black">{exp.title}</div>
            <div class="text-sm font-semibold text-primary">{exp.company}</div>
            <p class="mt-1">{exp.description}</p>
          </div>
          <hr class="bg-primary" />
        </li>
      ))}
    </ul>
  </section>
</Layout>

---
import { siteConfig } from "../config";

const greetings = [
  `Hi, I'm ${siteConfig.name} ${siteConfig.surname}`,
  `Welcome, I'm ${siteConfig.nickname}`,
  `Hey there! I'm ${siteConfig.name}`,
  `Hello! Call me ${siteConfig.nickname}`,
  `Nice to meet you, I'm ${siteConfig.name} ${siteConfig.surname}`,
];
---

<section class="min-h-[calc(100vh-68px)] flex items-center justify-center bg-gradient-to-br from-gray-900 via-gray-900 to-gray-800/30 relative overflow-hidden">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,oklch(0.6_0.25_270_/_0.08),transparent_60%)]"></div>
  <div class="flex flex-col-reverse lg:flex-row-reverse items-center w-full max-w-6xl gap-10 lg:gap-20 px-4 relative z-10">
    <div class="flex-shrink-0 animate-fade-in-up" style="animation-delay: 0.2s;">
      <div>
        <div class="w-48 h-48 lg:w-72 lg:h-72 rounded-full ring-2 ring-purple-500 ring-offset-gray-900 ring-offset-4 overflow-hidden avatar-glow transition-shadow duration-500 hover:shadow-[0_0_40px_8px_oklch(0.6_0.25_270_/_0.45)]">
          <img
            src={siteConfig.photoUrl}
            alt={`${siteConfig.name} ${siteConfig.surname}`}
            class="object-cover w-full h-full"
          />
        </div>
      </div>
    </div>
    <div class="text-center lg:text-left animate-fade-in-up">
      <h1 id="greeting-text" class="text-4xl lg:text-6xl font-extrabold text-gradient leading-tight" data-greetings={JSON.stringify(greetings)}>
        {greetings[0]}
      </h1>
      <p class="py-6 text-lg max-w-md text-gray-400">{siteConfig.bio}</p>
      <div class="flex gap-4 justify-center lg:justify-start">
        <a href={`${import.meta.env.BASE_URL}about`} class="inline-flex items-center px-6 py-3 text-lg font-semibold rounded-lg bg-purple-600 text-white shadow-lg shadow-purple-600/20 hover:bg-purple-700 hover:shadow-purple-600/40 transition-all">About Me</a>
        <a href={`${import.meta.env.BASE_URL}#contact`} class="inline-flex items-center px-6 py-3 text-lg font-semibold rounded-lg border-2 border-purple-500 text-purple-400 hover:bg-purple-600 hover:text-white transition-all">Contact</a>
      </div>
    </div>
  </div>
</section>

<script>
  const el = document.getElementById("greeting-text");
  if (el) {
    const raw = el.dataset.greetings || "[]";
    const parsed: unknown = JSON.parse(raw);
    const greetings = Array.isArray(parsed) ? parsed.filter((g): g is string => typeof g === "string") : [];
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (greetings.length > 1 && !prefersReducedMotion) {
      let idx = 0;
      const intervalId = setInterval(() => {
        idx = (idx + 1) % greetings.length;
        el.style.opacity = "0";
        setTimeout(() => {
          el.textContent = greetings[idx];
          el.style.opacity = "1";
        }, 400);
      }, 3000);
      window.addEventListener("unload", () => clearInterval(intervalId));
    }
  }
</script>

<style>
  #greeting-text {
    transition: opacity 0.4s ease-in-out;
  }
</style>

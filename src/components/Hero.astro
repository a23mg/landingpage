---
import { siteConfig } from "../config";

const greetings = [
  `Hi, I'm ${siteConfig.name} ${siteConfig.surname}`,
  `Welcome, I'm ${siteConfig.nickname}`,
  `Hey there! I'm ${siteConfig.name}`,
  `Hello! Call me ${siteConfig.nickname}`,
  `Nice to meet you, I'm ${siteConfig.name} ${siteConfig.surname}`,
];
---

<section class="hero min-h-[calc(100vh-68px)] bg-gradient-to-br from-base-100 via-base-100 to-base-300/30 relative overflow-hidden">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,oklch(0.6_0.25_270_/_0.08),transparent_60%)]"></div>
  <div class="hero-content flex-col-reverse lg:flex-row-reverse w-full max-w-6xl gap-10 lg:gap-20 px-4 relative z-10">
    <div class="flex-shrink-0 animate-fade-in-up" style="animation-delay:0.2s">
      <div class="avatar">
        <div class="w-48 h-48 lg:w-72 lg:h-72 rounded-full ring-2 ring-primary ring-offset-base-100 ring-offset-4 overflow-hidden avatar-glow transition-shadow duration-500 hover:shadow-[0_0_40px_8px_oklch(0.6_0.25_270_/_0.45)]">
          <img
            src={siteConfig.photoUrl}
            alt={`${siteConfig.name} ${siteConfig.surname}`}
            class="object-cover w-full h-full"
          />
        </div>
      </div>
    </div>
    <div class="text-center lg:text-left animate-fade-in-up">
      <h1 id="greeting-text" class="text-4xl lg:text-6xl font-extrabold text-gradient leading-tight" data-greetings={JSON.stringify(greetings)}>
        {greetings[0]}
      </h1>
      <p class="py-6 text-lg max-w-md text-base-content/70">{siteConfig.bio}</p>
      <div class="flex gap-4 justify-center lg:justify-start">
        <a href={`${import.meta.env.BASE_URL}about`} class="btn btn-primary btn-lg shadow-lg shadow-primary/20 hover:shadow-primary/40 transition-shadow">About Me</a>
        <a href={`${import.meta.env.BASE_URL}#contact`} class="btn btn-outline btn-lg hover:btn-primary transition-all">Contact</a>
      </div>
    </div>
  </div>
</section>

<script>
  const el = document.getElementById("greeting-text");
  if (el) {
    const raw = el.dataset.greetings || "[]";
    const parsed: unknown = JSON.parse(raw);
    const greetings = Array.isArray(parsed) ? parsed.filter((g): g is string => typeof g === "string") : [];
    if (greetings.length > 1) {
      let idx = 0;
      const intervalId = setInterval(() => {
        idx = (idx + 1) % greetings.length;
        el.style.opacity = "0";
        setTimeout(() => {
          el.textContent = greetings[idx];
          el.style.opacity = "1";
        }, 400);
      }, 3000);
      window.addEventListener("unload", () => clearInterval(intervalId));
    }
  }
</script>

<style>
  #greeting-text {
    transition: opacity 0.4s ease-in-out;
  }
</style>
